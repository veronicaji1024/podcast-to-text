# AI API Configuration (Qwen/通义千问)
# SECURITY WARNING: Never commit real API keys to version control!
# If you've accidentally exposed your API key, regenerate it immediately.
OPENAI_API_KEY=your_qwen_api_key_here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus

# Server Configuration
PORT=3000
NODE_ENV=development

# DashScope ASR Configuration (云端语音转文字)
# Uses the same API key as OPENAI_API_KEY (DashScope API)
ASR_MODEL=paraformer-v2
# ASR timeout: 60 minutes supports up to 3-hour podcasts
ASR_TIMEOUT_MS=3600000

# File URL Service (for local file uploads with cloud ASR)
# Development: USE_TUNNEL=true (uses localtunnel to expose local files)
# Production: USE_OSS=true (uploads to Alibaba Cloud OSS)
USE_TUNNEL=true
USE_OSS=false
FILE_SERVER_PORT=3001

# Security: Secret for signing file URLs (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# IMPORTANT: Set this in production to prevent unauthorized file access
FILE_URL_SECRET=your_random_secret_here_generate_with_crypto

# Alibaba Cloud OSS Configuration (only needed if USE_OSS=true)
# OSS_REGION=oss-cn-hangzhou
# OSS_ACCESS_KEY_ID=your_access_key_id
# OSS_ACCESS_KEY_SECRET=your_access_key_secret
# OSS_BUCKET=your_bucket_name

# Processing timeout: 3 hours for very long podcasts
# Download (30min) + ASR (60min) + Optimize (30min) + Summarize (30min) = ~2.5 hours
PROCESS_TIMEOUT_MS=10800000

# Whisper Configuration (本地语音转文字，作为备选方案)
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# File Storage
TEMP_DIR=./server/temp
MAX_FILE_SIZE=500MB

# Optional: Proxy Configuration (for accessing OpenAI in certain regions)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
